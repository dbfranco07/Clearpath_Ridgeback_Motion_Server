# Copy to .env and fill in values
# cp sim/.env.example sim/.env

# Which VLM backend to use
# dgx  = real DGX endpoint (default, highest fidelity)
# mock = local mock server (offline/CI mode)
VLM_BACKEND=dgx

# DGX vLLM endpoint (update if IP/port changes)
VLM_ENDPOINT=http://10.158.36.90:8000/v1/chat/completions

# Which Gazebo world to load
# small_room | corridor | floor
SIM_WORLD=small_room

# Exploration strategy for sim missions
STRATEGY=frontier_nearest

# ROS2 domain (must match hardware domain)
ROS_DOMAIN_ID=0
