<?xml version="1.0" encoding="UTF-8"?>
<!--
  Ridgeback DDS profile. Static fallback used when RIDGEBACK_IP / JETSON_IP env
  vars are NOT set; otherwise scripts/generate_fastrtps_profile.py rewrites
  /tmp/fastrtps_ridgeback_generated.xml at launch time and that overrides this.

  Discovery is via metatraffic multicast; initialPeersList only adds hints for
  campus links where multicast may be filtered. Avoid hardcoding the Jetson IP
  here — it moves on every WiFi reconnect; export JETSON_IP / RIDGEBACK_IP
  before launch to get a fresh per-deploy unicast profile instead.
-->
<dds xmlns="http://www.eprosima.com/XMLSchemas/FastRTPS_Profiles">
    <profiles>
        <participant profile_name="participant_profile" is_default_profile="true">
            <rtps>
                <builtin>
                    <metatrafficMulticastLocatorList>
                        <locator>
                            <udpv4>
                                <address>239.255.0.1</address>
                                <port>7400</port>
                            </udpv4>
                        </locator>
                    </metatrafficMulticastLocatorList>
                    <initialPeersList>
                        <locator>
                            <udpv4>
                                <address>127.0.0.1</address>
                            </udpv4>
                        </locator>
                        <locator>
                            <udpv4>
                                <address>192.168.131.1</address>
                            </udpv4>
                        </locator>
                    </initialPeersList>
                </builtin>
            </rtps>
        </participant>
    </profiles>
</dds>
