<?xml version="1.0" encoding="UTF-8"?>
<!-- Ridgeback DDS profile: discover Jetson on WiFi + local Clearpath nodes -->
<dds xmlns="http://www.eprosima.com/XMLSchemas/FastRTPS_Profiles">
    <profiles>
        <participant profile_name="participant_profile" is_default_profile="true">
            <rtps>
                <builtin>
                    <metatrafficMulticastLocatorList>
                        <locator>
                            <udpv4>
                                <address>239.255.0.1</address>
                                <port>7400</port>
                            </udpv4>
                        </locator>
                    </metatrafficMulticastLocatorList>
                    <initialPeersList>
                        <locator>
                            <udpv4>
                                <address>jetson-ridgeback.local</address>
                            </udpv4>
                        </locator>
                        <locator>
                            <udpv4>
                                <address>127.0.0.1</address>
                            </udpv4>
                        </locator>
                        <locator>
                            <udpv4>
                                <address>192.168.131.1</address>
                            </udpv4>
                        </locator>
                        <!--
                          Jetson WiFi IP fallback. ridgeback_start.sh re-
                          generates this list at launch when JETSON_IP
                          resolves; this static entry only kicks in when
                          mDNS + auto-detection both fail.
                        -->
                        <locator>
                            <udpv4>
                                <address>10.158.38.136</address>
                            </udpv4>
                        </locator>
                    </initialPeersList>
                </builtin>
            </rtps>
        </participant>
    </profiles>
</dds>
