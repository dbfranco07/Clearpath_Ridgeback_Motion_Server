<?xml version="1.0" encoding="UTF-8"?>
<!--
  Jetson DDS profile. Static fallback used when JETSON_IP / RIDGEBACK_IP env
  vars are NOT set; otherwise scripts/generate_fastrtps_profile.py rewrites
  /tmp/fastrtps_jetson_generated.xml at launch time and that overrides this.

  Important: do NOT set defaultUnicastLocatorList here. Hardcoding it to a
  specific IP breaks all DDS data delivery whenever the Jetson's WiFi address
  changes. Letting FastDDS auto-discover interfaces is safer; initialPeersList
  below is only a discovery hint.
-->
<dds xmlns="http://www.eprosima.com/XMLSchemas/FastRTPS_Profiles">
    <profiles>
        <participant profile_name="participant_profile" is_default_profile="true">
            <rtps>
                <builtin>
                    <metatrafficMulticastLocatorList>
                        <locator>
                            <udpv4>
                                <address>239.255.0.1</address>
                                <port>7400</port>
                            </udpv4>
                        </locator>
                    </metatrafficMulticastLocatorList>
                    <initialPeersList>
                        <locator>
                            <udpv4>
                                <address>127.0.0.1</address>
                            </udpv4>
                        </locator>
                        <locator>
                            <udpv4>
                                <address>10.158.39.203</address>
                            </udpv4>
                        </locator>
                        <locator>
                            <udpv4>
                                <address>192.168.131.1</address>
                            </udpv4>
                        </locator>
                    </initialPeersList>
                </builtin>
            </rtps>
        </participant>
    </profiles>
</dds>
