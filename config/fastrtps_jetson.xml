<?xml version="1.0" encoding="UTF-8"?>
<!--
  Jetson DDS profile. Static fallback used when JETSON_IP / RIDGEBACK_IP env
  vars are NOT set; otherwise scripts/generate_fastrtps_profile.py rewrites
  /tmp/fastrtps_jetson_generated.xml at launch time and that overrides this.

  defaultUnicastLocatorList uses jetson-ridgeback.local (resolved via mDNS) so
  DDS binds to whatever IP the Jetson currently has on WiFi without needing the
  XML to be edited every reconnect.
-->
<dds xmlns="http://www.eprosima.com/XMLSchemas/FastRTPS_Profiles">
    <profiles>
        <participant profile_name="participant_profile" is_default_profile="true">
            <rtps>
                <defaultUnicastLocatorList>
                    <locator>
                        <udpv4>
                            <address>jetson-ridgeback.local</address>
                        </udpv4>
                    </locator>
                </defaultUnicastLocatorList>
                <builtin>
                    <initialPeersList>
                        <locator>
                            <udpv4>
                                <address>jetson-ridgeback.local</address>
                            </udpv4>
                        </locator>
                        <locator>
                            <udpv4>
                                <address>127.0.0.1</address>
                            </udpv4>
                        </locator>
                        <locator>
                            <udpv4>
                                <address>10.158.39.203</address>
                            </udpv4>
                        </locator>
                    </initialPeersList>
                </builtin>
            </rtps>
        </participant>
    </profiles>
</dds>
