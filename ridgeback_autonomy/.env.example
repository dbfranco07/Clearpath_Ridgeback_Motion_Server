# Copy this file to .env and fill in your VLM server details.
# This file is safe to commit; .env is gitignored.
#
# Usage:
#   cp .env.example .env
#   # Then edit .env with your actual values.
#
# Alternatively, set the RIDGEBACK_ENV_FILE env var to point to your .env:
#   export RIDGEBACK_ENV_FILE=/path/to/your/.env

VLM_ENDPOINT=http://YOUR_VLM_SERVER_IP:8000
VLM_PORT=8000
VLM_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
