# Query the spatial memory for a room's location
string room_id          # Room number to look up
---
bool found              # True if the room is in memory
float64 map_x           # Stored map coordinates
float64 map_y
float64 map_yaw
float32 confidence      # Confidence of the stored detection
string last_seen        # ISO timestamp of last detection
int32 detection_count   # How many times this room has been detected
